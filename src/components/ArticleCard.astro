---
import TagChip from './TagChip.astro';
import type { Article } from '../content.config';

interface Props {
  article: Article;
  index: number;
}

const { article, index } = Astro.props;
const anchorId = `article-${index}`;
---

<article
  id={anchorId}
  class="group relative rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-bg-card)] p-5 sm:p-6 transition-all hover:border-[color:var(--color-border-strong)] hover:bg-[color:var(--color-bg-elev)]"
>
  <div class="flex items-start gap-3 sm:gap-4">
    <div
      class="shrink-0 flex items-center justify-center w-9 h-9 rounded-lg bg-[color:var(--color-bg-elev)] text-[color:var(--color-text-muted)] font-bold text-sm tabular-nums border border-[color:var(--color-border)]"
    >
      {index}
    </div>

    <div class="min-w-0 flex-1">
      <h3 class="text-lg sm:text-xl font-bold tracking-tight text-balance leading-snug">
        <a
          href={article.sourceUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-[color:var(--color-accent-hover)] transition-colors"
        >
          {article.title}
        </a>
      </h3>

      <p class="mt-3 text-[color:var(--color-text-muted)] text-pretty">
        {article.summary}
      </p>

      <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-3">
        <div class="flex items-center gap-2 text-sm text-[color:var(--color-text-dim)]">
          <svg
            class="w-4 h-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"
            ></path>
            <path d="M18 14h-8M15 18h-5M10 6h8v4h-8V6Z"></path>
          </svg>
          <span>{article.source}</span>
        </div>

        <a
          href={article.sourceUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-[color:var(--color-accent)] hover:text-[color:var(--color-accent-hover)] transition-colors"
        >
          元記事を読む
          <svg
            class="w-3.5 h-3.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M7 17 17 7M7 7h10v10"></path>
          </svg>
        </a>

        {article.tags.length > 0 && (
          <div class="flex flex-wrap items-center gap-1.5 ml-auto">
            {article.tags.map((tag) => <TagChip tag={tag} />)}
          </div>
        )}
      </div>
    </div>
  </div>
</article>
