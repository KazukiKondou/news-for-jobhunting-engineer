---
import { SITE } from '../config';
const year = new Date().getFullYear();
---

<footer
  class="mt-24 border-t border-[color:var(--color-border)] py-8 text-sm text-[color:var(--color-text-dim)]"
>
  <div class="mx-auto max-w-5xl px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-between gap-3">
    <div>© {year} {SITE.author}</div>
    <div class="flex items-center gap-2">
      <span>毎日更新</span>
      <span class="opacity-50">·</span>
      <span>LINE配信と連動</span>
    </div>
  </div>
</footer>
