---
import { SITE } from '../config';
---

<header
  class="sticky top-0 z-50 backdrop-blur-md bg-[color:var(--color-bg)]/85 border-b border-[color:var(--color-border)]"
>
  <div class="mx-auto max-w-5xl px-4 sm:px-6 h-16 flex items-center justify-between gap-3">
    <a
      href="/"
      class="group flex items-center gap-2.5 font-bold tracking-tight min-w-0"
    >
      <span
        class="shrink-0 inline-flex items-center justify-center w-8 h-8 rounded-md bg-gradient-to-br from-sky-400 to-indigo-500 text-zinc-900 text-sm font-black"
        >N</span
      >
      <span class="text-base sm:text-lg truncate whitespace-nowrap">{SITE.title}</span>
    </a>

    <nav class="shrink-0 flex items-center gap-0.5 sm:gap-1 text-sm">
      <a
        href="/"
        class="px-2.5 sm:px-3 py-1.5 rounded-md whitespace-nowrap text-[color:var(--color-text-muted)] hover:text-[color:var(--color-text)] hover:bg-[color:var(--color-bg-elev)] transition-colors"
      >
        ホーム
      </a>
      <a
        href="/archive/"
        class="px-2.5 sm:px-3 py-1.5 rounded-md whitespace-nowrap text-[color:var(--color-text-muted)] hover:text-[color:var(--color-text)] hover:bg-[color:var(--color-bg-elev)] transition-colors"
      >
        アーカイブ
      </a>
    </nav>
  </div>
</header>
