---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ページが見つかりません" description="404 - Not Found">
  <section class="mx-auto max-w-3xl px-4 sm:px-6 py-24 text-center">
    <div class="font-display text-7xl sm:text-8xl font-black tracking-tight text-[color:var(--color-text-dim)]">
      404
    </div>
    <h1 class="mt-4 text-2xl sm:text-3xl font-bold">ページが見つかりません</h1>
    <p class="mt-3 text-[color:var(--color-text-muted)]">
      指定されたページは存在しないか、移動された可能性があります。
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[color:var(--color-accent)] text-zinc-900 font-semibold hover:bg-[color:var(--color-accent-hover)] transition-colors"
    >
      ホームに戻る
    </a>
  </section>
</BaseLayout>
