---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { formatDate, toSlug } from '../lib/date';

export const getStaticPaths = (async () => {
  const days = await getCollection('days');
  const sorted = days.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return sorted.map((day, idx) => ({
    params: { date: toSlug(day.data.date) },
    props: {
      day,
      prev: sorted[idx + 1] ?? null,
      next: sorted[idx - 1] ?? null,
    },
  }));
}) satisfies GetStaticPaths;

const { day, prev, next } = Astro.props;
const { date, articles, intro } = day.data;
const dateLabel = formatDate(date);
---

<BaseLayout
  title={dateLabel}
  description={`${dateLabel}のテックニュース ${articles.length}件: ${articles
    .slice(0, 3)
    .map((a) => a.title)
    .join(' / ')}`}
  pageType="article"
  publishedTime={date}
>
  <article class="mx-auto max-w-3xl px-4 sm:px-6 py-10 sm:py-14">
    <a
      href="/"
      class="inline-flex items-center gap-1.5 text-sm text-[color:var(--color-text-muted)] hover:text-[color:var(--color-text)] transition-colors"
    >
      <svg
        class="w-4 h-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="m12 19-7-7 7-7M19 12H5"></path>
      </svg>
      ホームに戻る
    </a>

    <header class="mt-8">
      <div class="text-xs font-semibold uppercase tracking-widest text-[color:var(--color-accent)]">
        Daily News
      </div>
      <h1 class="mt-3 font-display text-4xl sm:text-5xl font-black tracking-tight text-balance">
        {dateLabel}
      </h1>
      <p class="mt-3 text-[color:var(--color-text-muted)]">
        本日のニュース <span class="font-semibold text-[color:var(--color-text)]">{articles.length}</span> 件
      </p>

      {intro && (
        <p class="mt-5 text-[color:var(--color-text-muted)] text-pretty leading-relaxed">
          {intro}
        </p>
      )}
    </header>

    <nav
      class="mt-10 rounded-xl border border-[color:var(--color-border)] bg-[color:var(--color-bg-card)]/60 p-5 sm:p-6"
      aria-label="本日の見出し一覧"
    >
      <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-[color:var(--color-text-dim)]">
        <svg
          class="w-3.5 h-3.5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"></path>
        </svg>
        見出し一覧
      </div>
      <ol class="mt-4 space-y-2.5">
        {articles.map((article, idx) => (
          <li class="flex items-start gap-3">
            <span class="shrink-0 mt-0.5 text-sm font-bold tabular-nums text-[color:var(--color-text-dim)] w-6">
              {String(idx + 1).padStart(2, '0')}
            </span>
            <a
              href={`#article-${idx + 1}`}
              class="text-[color:var(--color-text)] hover:text-[color:var(--color-accent-hover)] transition-colors leading-snug"
            >
              {article.title}
            </a>
          </li>
        ))}
      </ol>
    </nav>

    <section class="mt-10 space-y-4 sm:space-y-5">
      {articles.map((article, idx) => (
        <ArticleCard article={article} index={idx + 1} />
      ))}
    </section>

    <nav
      class="mt-14 flex items-stretch gap-3 border-t border-[color:var(--color-border)] pt-8"
      aria-label="日付ナビゲーション"
    >
      {prev ? (
        <a
          href={`/${toSlug(prev.data.date)}/`}
          class="group flex-1 rounded-lg border border-[color:var(--color-border)] p-4 hover:border-[color:var(--color-border-strong)] hover:bg-[color:var(--color-bg-elev)] transition-colors"
        >
          <div class="text-xs text-[color:var(--color-text-dim)] flex items-center gap-1">
            <svg
              class="w-3 h-3 transition-transform group-hover:-translate-x-0.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m15 18-6-6 6-6"></path>
            </svg>
            前の日
          </div>
          <div class="mt-1 font-semibold tabular-nums">{formatDate(prev.data.date)}</div>
        </a>
      ) : (
        <div class="flex-1"></div>
      )}
      {next ? (
        <a
          href={`/${toSlug(next.data.date)}/`}
          class="group flex-1 rounded-lg border border-[color:var(--color-border)] p-4 hover:border-[color:var(--color-border-strong)] hover:bg-[color:var(--color-bg-elev)] transition-colors text-right"
        >
          <div class="text-xs text-[color:var(--color-text-dim)] flex items-center justify-end gap-1">
            次の日
            <svg
              class="w-3 h-3 transition-transform group-hover:translate-x-0.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </div>
          <div class="mt-1 font-semibold tabular-nums">{formatDate(next.data.date)}</div>
        </a>
      ) : (
        <div class="flex-1"></div>
      )}
    </nav>
  </article>
</BaseLayout>
