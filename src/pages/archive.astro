---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import DayCard from '../components/DayCard.astro';

const days = (await getCollection('days')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

// Group by year-month
const groups = new Map<string, typeof days>();
for (const day of days) {
  const key = `${day.data.date.getFullYear()}年${day.data.date.getMonth() + 1}月`;
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(day);
}
---

<BaseLayout title="アーカイブ" description="過去のニュース一覧">
  <section class="mx-auto max-w-5xl px-4 sm:px-6 py-12 sm:py-16">
    <header>
      <h1 class="text-4xl sm:text-5xl font-black tracking-tight">アーカイブ</h1>
      <p class="mt-2 text-[color:var(--color-text-muted)]">
        合計 {days.length} 日分のニュース
      </p>
    </header>

    {days.length === 0 ? (
      <div class="mt-10 rounded-xl border border-dashed border-[color:var(--color-border)] p-10 text-center text-[color:var(--color-text-muted)]">
        まだ記事がありません。
      </div>
    ) : (
      <div class="mt-10 space-y-12">
        {[...groups.entries()].map(([month, monthDays]) => (
          <div>
            <h2 class="text-lg font-bold text-[color:var(--color-text-muted)] mb-4">
              {month}
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {monthDays.map((day) => (
                <DayCard
                  date={day.data.date}
                  articleCount={day.data.articles.length}
                  highlights={day.data.articles.map((a) => a.title)}
                />
              ))}
            </div>
          </div>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
