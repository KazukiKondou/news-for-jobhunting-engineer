---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import DayCard from '../components/DayCard.astro';
import TagChip from '../components/TagChip.astro';
import { formatDate, toSlug } from '../lib/date';

const days = (await getCollection('days')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const latest = days[0];
const older = days.slice(1, 10);
---

<BaseLayout>
  {latest && (
    <section class="relative overflow-hidden border-b border-[color:var(--color-border)]">
      <div
        class="absolute inset-0 -z-10 opacity-50"
        style="background: radial-gradient(circle at 20% 0%, oklch(0.4 0.16 235 / 0.25), transparent 50%), radial-gradient(circle at 80% 30%, oklch(0.4 0.16 280 / 0.18), transparent 50%);"
      >
      </div>

      <div class="mx-auto max-w-5xl px-4 sm:px-6 py-12 sm:py-16">
        <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-[color:var(--color-accent)]">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[color:var(--color-accent)] opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-[color:var(--color-accent)]"></span>
          </span>
          最新のニュース
        </div>

        <h1 class="mt-4 font-display text-4xl sm:text-5xl md:text-6xl font-black tracking-tight text-balance">
          {formatDate(latest.data.date)}
        </h1>

        <p class="mt-3 text-[color:var(--color-text-muted)] text-lg">
          本日のニュース {latest.data.articles.length} 件
        </p>

        {latest.data.intro && (
          <p class="mt-4 max-w-3xl text-[color:var(--color-text-muted)] text-pretty">
            {latest.data.intro}
          </p>
        )}

        <ul class="mt-8 space-y-2.5 max-w-3xl">
          {latest.data.articles.slice(0, 5).map((article, idx) => (
            <li class="flex items-start gap-3">
              <span class="shrink-0 mt-1 text-sm font-bold tabular-nums text-[color:var(--color-text-dim)] w-5">
                {String(idx + 1).padStart(2, '0')}
              </span>
              <a
                href={`/${toSlug(latest.data.date)}/#article-${idx + 1}`}
                class="group text-[color:var(--color-text)] hover:text-[color:var(--color-accent-hover)] transition-colors leading-snug"
              >
                {article.title}
                <span class="ml-2 text-xs text-[color:var(--color-text-dim)]">
                  {article.source}
                </span>
              </a>
            </li>
          ))}
          {latest.data.articles.length > 5 && (
            <li class="text-sm text-[color:var(--color-text-dim)] pl-8">
              他 {latest.data.articles.length - 5} 件
            </li>
          )}
        </ul>

        <div class="mt-10 flex flex-wrap items-center gap-3">
          <a
            href={`/${toSlug(latest.data.date)}/`}
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[color:var(--color-accent)] text-zinc-900 font-semibold hover:bg-[color:var(--color-accent-hover)] transition-colors"
          >
            すべての記事を読む
            <svg
              class="w-4 h-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <section class="mx-auto max-w-5xl px-4 sm:px-6 py-12 sm:py-16">
    {!latest && (
      <div class="rounded-xl border border-dashed border-[color:var(--color-border)] p-10 text-center text-[color:var(--color-text-muted)]">
        まだ記事がありません。
      </div>
    )}

    {older.length > 0 && (
      <>
        <h2 class="text-2xl font-bold tracking-tight">過去のニュース</h2>
        <p class="mt-1 text-sm text-[color:var(--color-text-dim)]">
          直近 {older.length} 日分
        </p>
        <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {older.map((day) => (
            <DayCard
              date={day.data.date}
              articleCount={day.data.articles.length}
              highlights={day.data.articles.map((a) => a.title)}
            />
          ))}
        </div>
        <div class="mt-8">
          <a
            href="/archive/"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[color:var(--color-accent)] hover:text-[color:var(--color-accent-hover)]"
          >
            すべてのアーカイブを見る
            <svg
              class="w-3.5 h-3.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m9 18 6-6-6-6"></path>
            </svg>
          </a>
        </div>
      </>
    )}
  </section>
</BaseLayout>
